generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ─── ENUMS ───────────────────────────────────────────────────────

enum Role {
  ADMIN
  ORGANIZER
  PLAYER
}

enum TournamentStatus {
  UPCOMING
  PENDING
  OPEN
  ONGOING
  COMPLETED
}

// The underlying bracket engines — hardcoded, never user-defined
enum TournamentSystem {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  SWISS
  ROUND_ROBIN
  HYBRID   // multi-phase: e.g. Swiss → Top Cut Elimination
}

enum MatchStatus {
  PENDING
  ONGOING
  COMPLETED
}

// ─── MODELS ──────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String?   @unique
  username        String?   @unique
  hashedPassword  String?
  isGuest         Boolean   @default(false)
  roles           Role[]    @default([PLAYER])
  expiresAt       DateTime?
  isExpired       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updateAt        DateTime  @updatedAt()

  tournamentsCreated       Tournament[]
  wonTournaments           Tournament[]        @relation("TournamentWinner")
  participatedTournaments  TournamentParticipant[]
  matchesAsPlayer1         Match[]             @relation("Player1")
  matchesAsPlayer2         Match[]             @relation("Player2")
  wonMatches               Match[]             @relation("Winner")
  createdFormats           TournamentFormat[]
}

// ─── TOURNAMENT FORMAT (Admin-managed named rulesets) ─────────────

model TournamentFormat {
  id          String           @id @default(uuid())
  name        String           @unique      // "Beyblade Standard", "Pickleball Open"
  description String?
  gameName    String?                       // Dynamic game association (e.g. "Pickleball")
  system      TournamentSystem             // the engine to run
  config      Json                         // all rules as JSON blob
  isBuiltin   Boolean          @default(false) // builtin formats cannot be deleted

  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Cascade)

  tournaments Tournament[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// ─── TOURNAMENT ───────────────────────────────────────────────────

model Tournament {
  id          String   @id @default(uuid())
  name        String
  maxPlayers  Int
  prizePool   Float?
  entranceFee Float?
  venue       String?
  date        DateTime?
  inviteToken String   @default(uuid()) @unique
  isPrivate   Boolean  @default(false)
  status      TournamentStatus @default(OPEN)

  // Format reference — points to admin-defined named ruleset
  formatId    String?
  format      TournamentFormat? @relation(fields: [formatId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  winnerId    String?
  winner      User? @relation("TournamentWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  winnerName  String?

  guestCleanupAt DateTime?

  participants TournamentParticipant[]
  rounds       Round[]

  createdAt DateTime @default(now())
}

// ─── PARTICIPANTS ─────────────────────────────────────────────────

model TournamentParticipant {
  id            String @id @default(uuid())
  userId        String
  tournamentId  String

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  seed          Int?

  @@unique([userId, tournamentId])
}

// ─── ROUNDS & MATCHES ─────────────────────────────────────────────

model Round {
  id            String @id @default(uuid())
  tournamentId  String
  roundNumber   Int

  matches       Match[]

  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, roundNumber])
}

model Match {
  id            String @id @default(uuid())

  roundId       String
  round         Round @relation(fields: [roundId], references: [id])

  player1Id     String?
  player2Id     String?

  player1       User? @relation("Player1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2       User? @relation("Player2", fields: [player2Id], references: [id], onDelete: SetNull)

  player1Score  Int @default(0)
  player2Score  Int @default(0)

  // Historical name snapshots — populated when a user is deleted
  p1Name        String?
  p2Name        String?
  winnerName    String?

  winnerId      String?
  winner        User? @relation("Winner", fields: [winnerId], references: [id], onDelete: SetNull)

  nextMatchId   String?
  nextMatch     Match? @relation("NextMatch", fields: [nextMatchId], references: [id])
  previousMatches Match[] @relation("NextMatch")

  loserNextMatchId String?
  loserNextMatch   Match? @relation("LoserNextMatch", fields: [loserNextMatchId], references: [id])
  previousLoserMatches Match[] @relation("LoserNextMatch")

  status        MatchStatus @default(PENDING)
  isBye         Boolean @default(false)

  // For HYBRID tournaments: which phase this match belongs to
  phase         Int @default(1)

  createdAt     DateTime @default(now())
}